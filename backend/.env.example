APP_NAME=SimpleVPBot
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

APP_LOCALE=fa
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=simplevpbot
DB_USERNAME=svp
DB_PASSWORD=secret

SVP_ADMIN_USERNAME=admin
SVP_ADMIN_PASSWORD=changeme

SVP_MODULE_TELEGRAM=true
SVP_MODULE_BALE=true
SVP_MODULE_XUI_PANEL=true
SVP_MODULE_RELAY=false
SVP_MODULE_CRYPTO=false
SVP_MODULE_L2TP=false
SVP_MODULE_MARKETING=true
SVP_MODULE_RESELLER=true
SVP_MODULE_BACKUP=true

SVP_QUEUE_DRAIN_KEY=
SVP_WEBHOOK_RATE_LIMIT_PER_MIN=120
SVP_WEBHOOK_RESELLER_RATE_LIMIT_PER_MIN=60
SVP_RATE_LIMIT_TRUST_FORWARDED_FOR=false
SVP_PORTAL_LINK_SECRET=
SVP_HEALTH_DEEP_TOKEN=
SVP_BACKUP_INTERVAL_MINUTES=60
SVP_ADMIN_STATE_RATE_LIMIT=60
SVP_ADMIN_MUTATE_RATE_LIMIT=300
SVP_LOGIN_RATE_LIMIT=10
SVP_RELAY_SHARED_SECRET=
SVP_RELAY_ADMIN_URL=
SVP_RELAY_PUBLIC_URL=
SVP_RELAY_VPS_IP=

# Optional bot tokens (also stored encrypted in svp_settings after mutate)
SVP_TELEGRAM_BOT_TOKEN=
SVP_TELEGRAM_WEBHOOK_SECRET=
SVP_BALE_BOT_TOKEN=
SVP_BALE_WEBHOOK_SECRET=

# Crypto / NOWPayments (module crypto)
SVP_CRYPTO_NOWPAYMENTS_API_KEY=
SVP_CRYPTO_NOWPAYMENTS_IPN_SECRET=
SVP_CRYPTO_IPN_PATH_SECRET=

# Relay TLS verification when calling relay admin API (default true in production)
SVP_RELAY_SSL_VERIFY=true

# Backup delivery
SVP_BACKUP_STORE_ON_SITE=true
SVP_BACKUP_TELEGRAM_CHAT_ID=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
# Production: e.g. .example.com (see spec §5.3)
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,127.0.0.1,127.0.0.1:8080

# Encryption: Laravel Crypt uses APP_KEY (spec §9 SVP_ENCRYPTION_KEY — intentionally unified; see SPEC-DEVIATIONS-FA.md)
# SVP_ENCRYPTION_KEY=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

MAIL_MAILER=log
